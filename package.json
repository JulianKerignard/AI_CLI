{
  "name": "aicli",
  "version": "0.1.0",
  "description": "Un CLI interactif à la Claude Code : slash commands, skills, sub-agents, MCP — avec provider démo (pas de clé API).",
  "type": "module",
  "bin": {
    "aicli": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p .",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p . --noEmit",
    "prepare": "tsc -p . || true"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "dependencies": {
    "@inquirer/input": "^5.0.12",
    "@inquirer/search": "^4.1.8",
    "@inquirer/select": "^5.1.4",
    "chalk": "^5.3.0",
    "ink": "^7.0.1",
    "react": "^19.2.5",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
